{% block password_repeated_row %}
    {% set actionShowTranslated = 'action.visibility.show'|trans %}

    <div class="js-password-repeated-wrapper">
        <div class="mb-3">
            {{ form_label(form.first) }}
            {{ form_widget(form.first) }}
            {{ form_help(form.first) }}

            <button
                class="btn btn-secondary btn-sm mt-2"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#passwordRequirements"
                aria-expanded="false"
                aria-controls="passwordRequirements"
            >
                <span
                    class="js-toggler-action-info"
                    data-action-hide="{{ 'action.visibility.hide'|trans }}"
                    data-action-show="{{ actionShowTranslated }}"
                >
                    {{ actionShowTranslated }}
                </span>
                {{ 'message.password_full_requirements'|trans(domain='forms') }}
            </button>

            <div class="collapse mt-2" id="passwordRequirements">
                <div class="card card-body small">
                    {{ passwordRequirementsInfoFull|raw }}
                </div>
            </div>

            {% if form_errors(form.first) is not empty %}
                <div class="mt-2">
                    {{ form_errors(form.first) }}
                </div>
            {% endif %}
        </div>

        {{ form_row(form.second) }}
    </div>
{% endblock %}
