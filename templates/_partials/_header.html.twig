{% set areNonDefaultLocalesAvailable
    = (app.enabled_locales|length > 1)
    or (app.enabled_locales|length == 1 and (app.enabled_locales|first is not same as app.request.defaultLocale))
%}
{% set pathAccountIndex = path(constant('App\\Controller\\AccountController::ROUTE_INDEX')) %}
{% set pathAdminDashboardIndex = path(constant('App\\Controller\\Admin\\DashboardController::ROUTE_INDEX')) %}
{% set pathAuthRegistrationRegister = path(constant('App\\Controller\\Auth\\RegistrationController::ROUTE_REGISTER')) %}
{% set pathAuthSecurityLogin = path(constant('App\\Controller\\Auth\\SecurityController::ROUTE_LOGIN')) %}
{% set pathAuthSecurityLogout = path(constant('App\\Controller\\Auth\\SecurityController::ROUTE_LOGOUT')) %}
{% set pathMainHomepage = path(constant('App\\Controller\\MainController::ROUTE_HOMEPAGE')) %}

<header>
    <nav class="navigation-bar navbar fixed-top bg-body-tertiary" data-bs-theme="light">
        <div class="container-xxl">
            <a class="navigation-bar__brand font-ibm-plex-mono" href="{{ pathMainHomepage }}">
                <span class="navigation-bar__brand-letter">P</span>
                <span class="navigation-bar__brand-letter">O</span>
                <span class="navigation-bar__brand-letter">L</span>
                <span class="navigation-bar__brand-letter">L</span>
                <span class="navigation-bar__brand-letter">Y</span>
            </a>

            {% if is_granted('IS_AUTHENTICATED') %}
                <div class="navigation-bar__account-menu order-md-2">
                    <button
                        class="navigation-bar__account-menu-toggler"
                        data-bs-toggle="dropdown"
                        aria-expanded="false"
                    >
                        {{ 'menu.account.base.my_account'|trans }}
                    </button>
                    <ul class="navigation-bar__account-menu-dropdown dropdown-menu dropdown-menu-md-end">
                        {% if is_granted(enum('App\\Enum\\AuthorizationRole').Admin.value) %}
                            <li>
                                <a
                                    class="navigation-bar__account-menu-dropdown-item"
                                    href="{{ pathAdminDashboardIndex }}"
                                >
                                    {{ 'menu.account.base.admin_area'|trans }}
                                </a>
                            </li>
                        {% endif %}
                        <li>
                            <a class="navigation-bar__account-menu-dropdown-item" href="{{ pathAccountIndex }}">
                                {{ 'menu.account.base.account'|trans }}
                            </a>
                        </li>
                        <li>
                            <hr class="dropdown-divider">
                        </li>
                        <li>
                            <a class="navigation-bar__account-menu-dropdown-item" href="{{ pathAuthSecurityLogout }}">
                                {{ 'action.auth.logout'|trans }}
                            </a>
                        </li>
                    </ul>
                </div>
            {% endif %}

            <button
                class="navigation-bar__toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarCollapse"
                aria-controls="navbarCollapse"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navigation-bar__toggler-icon"></span>
            </button>
            <div class="navigation-bar__collapse collapse order-md-0" id="navbarCollapse">
                <ul class="navigation-bar__nav navbar-nav">
                    <li class="navigation-bar__nav-item">
                        <a class="navigation-bar__nav-link" href="{{ pathMainHomepage }}">
                            {{ 'menu.header.homepage'|trans }}
                        </a>
                    </li>
                </ul>

                {% if not is_granted('IS_AUTHENTICATED') %}
                    <div class="navigation-bar__sign-buttons order-md-1">
                        <a
                            class="navigation-bar__sign-button navigation-bar__sign-button--in"
                            href="{{ pathAuthSecurityLogin }}"
                        >
                            {{ 'action.auth.login'|trans }}
                        </a>
                        <a
                            class="navigation-bar__sign-button navigation-bar__sign-button--up"
                            href="{{ pathAuthRegistrationRegister }}"
                        >
                            {{ 'action.auth.register'|trans }}
                        </a>
                    </div>
                {% endif %}

                {%  if (areNonDefaultLocalesAvailable) %}
                    <div class="navigation-bar__language-switcher">
                        {{ include('components/language_switcher.html.twig') }}
                    </div>
                {% endif %}
            </div>
        </div>
    </nav>
</header>
